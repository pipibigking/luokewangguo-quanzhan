{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://luokewangguo-quanzhan-production.up.railway.app/api/$1"
    },
    {
      "src": "/images/(.*)",
      "dest": "https://luokewangguo-quanzhan-production.up.railway.app/images/$1"
    },
    {
      "src": "/icons/(.*)",
      "dest": "https://luokewangguo-quanzhan-production.up.railway.app/icons/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/$1"
    }
  ]
}